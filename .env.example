# Database URLs
AUTH_DB_URL=jdbc:postgresql://localhost:8001/bakery_auth
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password

PRODUCT_DB_URL=jdbc:postgresql://localhost:8002/bakery_products
PRODUCT_DB_USER=product_user
PRODUCT_DB_PASSWORD=product_password

ORDER_DB_URL=jdbc:postgresql://localhost:8003/bakery_orders
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=order_password

PAYMENT_DB_URL=jdbc:postgresql://localhost:8004/bakery_payments
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=payment_password

CART_DB_URL=jdbc:postgresql://localhost:8005/bakery_carts
CART_DB_USER=cart_user
CART_DB_PASSWORD=cart_password

NOTIFICATION_DB_URL=jdbc:postgresql://localhost:8006/bakery_notifications
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=notification_password

# Redis
REDIS_HOST=localhost
REDIS_PORT_AUTH=6379
REDIS_PORT_CART=6379
REDIS_PORT_PRODUCT=6380

# JWT
JWT_SECRET=your_jwt_secret_key_here_for_local_development

# AWS / Cloudflare R2
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_S3_ENDPOINT=https://your-s3-endpoint.r2.cloudflarestorage.com
AWS_S3_PUBLIC_URL=https://pub-your-public-url.r2.dev

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Elasticsearch
ELASTICSEARCH_URIS=http://localhost:9200
