# ==========================================
# Bakery Microservices Environment Variables
# ==========================================

# ------------------------------------------
# Application Profile
# ------------------------------------------
# ACTIVE_PROFILE dictates which local application-[profile].yml is loaded.
ACTIVE_PROFILE=prod

# ------------------------------------------
# API Gateway
# ------------------------------------------
API_GATEWAY_URL=http://production-gateway:8080

# ------------------------------------------
# Eureka Service Discovery
# ------------------------------------------
EUREKA_HOSTNAME=production-eureka
EUREKA_URL=http://production-eureka:8761/eureka/

# ------------------------------------------
# Databases (PostgreSQL)
# ------------------------------------------
AUTH_DB_URL=jdbc:postgresql://production-db:5432/bakery_auth
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=your_secure_password

CART_DB_URL=jdbc:postgresql://production-db:5432/bakery_carts
CART_DB_USER=cart_user
CART_DB_PASSWORD=your_secure_password

NOTIFICATION_DB_URL=jdbc:postgresql://production-db:5432/bakery_notifications
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=your_secure_password

ORDER_DB_URL=jdbc:postgresql://production-db:5432/bakery_orders
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=your_secure_password

PAYMENT_DB_URL=jdbc:postgresql://production-db:5432/bakery_payments
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=your_secure_password

PRODUCT_DB_URL=jdbc:postgresql://production-db:5432/bakery_products
PRODUCT_DB_USER=product_user
PRODUCT_DB_PASSWORD=your_secure_password

# ------------------------------------------
# Message Brokers & Caching
# ------------------------------------------
REDIS_HOST=production-redis
REDIS_PORT_AUTH=6379
REDIS_PORT_CART=6379
REDIS_PORT_PRODUCT=6380

KAFKA_BOOTSTRAP_SERVERS=production-kafka:9092

ELASTICSEARCH_URIS=http://production-elastic:9200

# ------------------------------------------
# Security & JWT
# ------------------------------------------
JWT_SECRET=your_production_jwt_secret

# ------------------------------------------
# Initial Admin Seed Data
# ------------------------------------------
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin
ADMIN_EMAIL=admin@yourproduction.com
ADMIN_PASSWORD=strong_admin_password
ADMIN_PHONE=1234567890

# ------------------------------------------
# AWS SNS & Core Services
# ------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

AWS_SNS_ANDROID_PLATFORM_ARN=arn:aws:sns:us-east-1:123456789:app/FCM/ProductionApp-Android
AWS_SNS_GENERAL_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:production-general-notifications
AWS_SNS_MARKETING_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:production-marketing
AWS_SNS_ORDERS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:production-orders

# ------------------------------------------
# Cloudflare R2 (S3 Compatible Storage)
# ------------------------------------------
R2_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
R2_CDN_URL=https://your-cdn.r2.dev
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key

# ------------------------------------------
# Notifications (Email & SMS)
# ------------------------------------------
MAIL_USERNAME=your-email@production.com
MAIL_PASSWORD=your_mail_password

BREVO_API_KEY=your_brevo_api_key

NOTIFICATION_FROM_EMAIL=noreply@production.com
NOTIFICATION_REPLY_TO=support@production.com

TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890

SMS_ENABLED=true
PUSH_ENABLED=true

# ------------------------------------------
# Payment Gateways
# ------------------------------------------
STRIPE_API_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

PAYPAL_CLIENT_ID=live_client_id
PAYPAL_CLIENT_SECRET=live_client_secret

SQUARE_ACCESS_TOKEN=live_access_token

# ------------------------------------------
# Spring Cloud Config Server
# ------------------------------------------
CONFIG_SERVER_URL=http://config-server:8021
